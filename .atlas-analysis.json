    "events.getEventAvailability - Get ticket availability",
    "events.getSellerEvents - Get seller's events with metrics",
    "tickets.getUserTicketForEvent - Get user's ticket for specific event",
    "tickets.getTicketWithDetails - Get ticket with event details",
    "tickets.updateTicketStatus - Update ticket status",
    "users.getUsersStripeConnectId - Get user's Stripe Connect ID",
    "waiting_list.getQueuePosition - Get position in waiting list",
    "createStripeCheckoutSession - Create payment session",
    "createStripeConnectCustomer - Create Stripe Connect customer",
    "refundEventTicket - Process ticket refund"
